# Optional: improves GitHub API rate limits and enables private repository access
GITHUB_TOKEN=

# Required for competition submission: GMI Cloud Inference Engine
# Never commit your real API key. Put it in .env.local only.
GMI_BASE_URL=https://api.gmi-serving.com/v1
GMI_API_KEY=
GMI_MODEL=deepseek-ai/DeepSeek-V4-Pro
GMI_TEMPERATURE=0.4
GMI_MAX_TOKENS=128000

# Optional: store published result pages (UGC) using Upstash Redis REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
